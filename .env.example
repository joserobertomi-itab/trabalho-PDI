# Docker Compose environment (copy to .env and adjust).

DATA=./data/Train_and_Validation
OUT=./result
CALIB=./calibration
LIMIT=3
PORT=8765

# --- Gentle on the host (defaults keep desktop usable) ---
# Max CPUs for batch services (pipeline/calibrate). Lower = slower but smoother.
DOCKER_CPUS=1.0
# RAM cap for pipeline/calibrate. Review uses half of this by default in compose.
DOCKER_MEMORY=1536m
# BLAS / numpy thread count — keep at 1 on laptops to avoid CPU spikes.
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
# Process priority inside the container (10 = low; 19 = lowest).
NICE_LEVEL=10
# IO priority: class 3 = idle (only when disk is free).
IONICE_CLASS=3
IONICE_LEVEL=7

# More headroom on a strong desktop (optional):
# DOCKER_CPUS=2.0
# DOCKER_MEMORY=3072m
# OMP_NUM_THREADS=2
# NICE_LEVEL=5

# Assignment/submission layout (real folder — not a symlink):
# DATA=./dataset
